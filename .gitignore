# ============================================================
# DATA - Privacy & Storage
# ============================================================

# Không push ảnh thực tế hoặc dữ liệu sinh ra từ pipeline
data/raw/
data/interim/
data/processed/
data/embeddings/
data/temp/
data/detected_faces/
data/aligned_faces/

# Không push metadata thật
data/metadata/*.csv
data/metadata/*.json

# Chỉ cho phép metadata mẫu / schema nếu có
!data/metadata/*_sample.csv
!data/metadata/*_schema.json

# Giữ cấu trúc thư mục rỗng trên GitHub
!**/.gitkeep


# ============================================================
# MODELS - Heavy Files
# ============================================================

models/pretrained/
models/trained/

*.pth
*.pt
*.h5
*.onnx
*.weights
*.pkl


# ============================================================
# LOGS & EXPERIMENTS
# ============================================================

logs/
experiments/

# Cho phép lưu lại file config experiment nếu cần
!experiments/*.yaml
!experiments/*.json


# ============================================================
# REPORTS & VISUALIZATIONS GENERATED BY PIPELINE
# ============================================================

reports/visualizations/
reports/face_detection/*.csv
reports/figures/
reports/tables/


# ============================================================
# PYTHON
# ============================================================

__pycache__/
*.py[cod]
*$py.class

.env
.venv/
venv/
env/

build/
dist/
*.egg-info/


# ============================================================
# JUPYTER NOTEBOOKS
# ============================================================

.ipynb_checkpoints/
*/.ipynb_checkpoints/*


# ============================================================
# EDITOR / OS FILES
# ============================================================

.vscode/
.DS_Store
Thumbs.db


# ============================================================
# CONFIGS - Security
# ============================================================

configs/credentials.yaml
configs/local_settings.py